generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id             String          @id @default(uuid())
  supabaseId     String          @unique
  email          String          @unique
  displayName    String
  role           String          @default("PLAYER")
  mfaEnabled     Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  mfaSecret      String?
  passwordHash   String?
  refreshToken   String?
  auditLogs      AuditLog[]      @relation("ActorLogs")
  portfolios     Portfolio[]
  sessionPlayers SessionPlayer[]

  @@index([supabaseId])
  @@index([email])
  @@map("users")
}

model GameSession {
  id            String          @id @default(uuid())
  code          String          @unique
  name          String
  status        String          @default("WAITING")
  scenarioId    String          @default("TECH_CRISIS")
  facilitatorId String
  maxPlayers    Int             @default(20)
  roundNumber   Int             @default(0)
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  macroStates   MacroState[]
  marketEvents  MarketEvent[]
  rounds        Round[]
  players       SessionPlayer[]

  @@index([code])
  @@index([status])
  @@map("game_sessions")
}

model SessionPlayer {
  id        String      @id @default(uuid())
  sessionId String
  userId    String
  joinedAt  DateTime    @default(now())
  isActive  Boolean     @default(true)
  portfolio Portfolio?
  user      User        @relation(fields: [userId], references: [id])
  session   GameSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, userId])
  @@map("session_players")
}

model Round {
  id            String      @id @default(uuid())
  sessionId     String
  roundNumber   Int
  startedAt     DateTime    @default(now())
  endedAt       DateTime?
  priceSnapshot String
  portfolios    Portfolio[]
  session       GameSession @relation(fields: [sessionId], references: [id])
  trades        Trade[]

  @@unique([sessionId, roundNumber])
  @@map("rounds")
}

model Portfolio {
  id              String         @id @default(uuid())
  userId          String
  sessionPlayerId String?        @unique
  roundId         String?
  cashBalance     Float          @default(100000)
  totalValue      Float?
  returnPct       Float?
  rank            Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  holdings        Holding[]
  round           Round?         @relation(fields: [roundId], references: [id])
  sessionPlayer   SessionPlayer? @relation(fields: [sessionPlayerId], references: [id])
  user            User           @relation(fields: [userId], references: [id])
  trades          Trade[]

  @@index([userId])
  @@index([roundId])
  @@map("portfolios")
}

model Holding {
  id          String    @id @default(uuid())
  portfolioId String
  assetId     String
  quantity    Float
  avgCost     Float
  updatedAt   DateTime  @updatedAt
  asset       Asset     @relation(fields: [assetId], references: [id])
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id])

  @@unique([portfolioId, assetId])
  @@map("holdings")
}

model Asset {
  id        String       @id @default(uuid())
  symbol    String       @unique
  name      String
  type      String
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  prices    AssetPrice[]
  holdings  Holding[]
  trades    Trade[]

  @@map("assets")
}

model AssetPrice {
  id          String   @id @default(uuid())
  assetId     String
  price       Float
  delta       Float    @default(0)
  sessionId   String?
  roundNumber Int?
  recordedAt  DateTime @default(now())
  asset       Asset    @relation(fields: [assetId], references: [id])

  @@index([assetId, roundNumber])
  @@map("asset_prices")
}

model MacroState {
  id              String      @id @default(uuid())
  sessionId       String
  roundNumber     Int
  interestRate    Float       @default(2.5)
  inflation       Float       @default(3.0)
  gdpGrowth       Float       @default(2.8)
  volatility      Float       @default(0.3)
  blackSwanActive Boolean     @default(false)
  blackSwanTier   Int?
  blackSwanEvent  String?
  createdAt       DateTime    @default(now())
  session         GameSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, roundNumber])
  @@map("macro_states")
}

model Trade {
  id          String    @id @default(uuid())
  portfolioId String
  assetId     String
  roundId     String
  action      String
  quantity    Float
  price       Float
  total       Float
  executedAt  DateTime  @default(now())
  round       Round     @relation(fields: [roundId], references: [id])
  asset       Asset     @relation(fields: [assetId], references: [id])
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id])

  @@index([portfolioId])
  @@index([roundId])
  @@map("trades")
}

model MarketEvent {
  id          String      @id @default(uuid())
  sessionId   String
  roundNumber Int
  title       String
  description String
  impact      String
  triggeredAt DateTime    @default(now())
  session     GameSession @relation(fields: [sessionId], references: [id])

  @@map("market_events")
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  action    String
  resource  String
  metadata  String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  actor     User?    @relation("ActorLogs", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
