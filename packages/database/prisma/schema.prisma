generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  FACILITATOR
  PLAYER
}

enum SessionStatus {
  WAITING
  ACTIVE
  NEWS_BREAK
  PAUSED
  COMPLETED
}

enum PlayerStatus {
  ACTIVE
  DROPPED
  KICKED
}

enum AssetType {
  STOCK
  BOND
  COMMODITY
  CRYPTO
  CASH
  REAL_ESTATE
}

model User {
  id             String          @id @default(uuid())
  supabaseId     String          @unique
  email          String          @unique
  firstName      String          @default("")
  lastName       String          @default("")
  displayName    String?         // Deprecated, use firstName + lastName
  role           UserRole        @default(PLAYER)
  mfaEnabled     Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  mfaSecret      String?
  passwordHash   String?
  refreshToken   String?
  auditLogs      AuditLog[]      @relation("ActorLogs")
  portfolios     Portfolio[]
  sessionPlayers SessionPlayer[]

  @@index([supabaseId])
  @@index([email])
  @@map("users")
}

model GameSession {
  id            String          @id @default(uuid())
  code          String          @unique
  name          String
  status        SessionStatus   @default(WAITING)
  scenarioId    String          @default("TECH_CRISIS")
  facilitatorId String
  maxPlayers    Int             @default(20)
  roundNumber   Int             @default(0)
  totalRounds   Int             @default(5)
  format        String          @default("STANDARD")
  blackSwanEnabled Boolean      @default(false)
  blackSwanRoundCount Int      @default(0)
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  macroStates   MacroState[]
  marketEvents  MarketEvent[]
  rounds        Round[]
  players       SessionPlayer[]

  @@index([code])
  @@index([status])
  @@map("game_sessions")
}

model SessionPlayer {
  id        String      @id @default(uuid())
  sessionId String
  userId    String
  joinedAt  DateTime    @default(now())
  isActive  Boolean     @default(true)
  status    PlayerStatus @default(ACTIVE)
  portfolio Portfolio?
  user      User        @relation(fields: [userId], references: [id])
  session   GameSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, userId])
  @@map("session_players")
}

model Round {
  id            String      @id @default(uuid())
  sessionId     String
  roundNumber   Int
  startedAt     DateTime    @default(now())
  endedAt       DateTime?
  priceSnapshot String
  portfolios    Portfolio[]
  session       GameSession @relation(fields: [sessionId], references: [id])
  trades        Trade[]

  @@unique([sessionId, roundNumber])
  @@map("rounds")
}

model Portfolio {
  id              String         @id @default(uuid())
  userId          String
  sessionPlayerId String?        @unique
  roundId         String?
  cashBalance     Float          @default(100000)
  totalValue      Float?
  returnPct       Float?
  rank            Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  holdings        Holding[]
  round           Round?         @relation(fields: [roundId], references: [id])
  sessionPlayer   SessionPlayer? @relation(fields: [sessionPlayerId], references: [id])
  user            User           @relation(fields: [userId], references: [id])
  trades          Trade[]

  @@index([userId])
  @@index([roundId])
  @@map("portfolios")
}

model Holding {
  id          String    @id @default(uuid())
  portfolioId String
  assetId     String
  quantity    Float
  avgCost     Float
  updatedAt   DateTime  @updatedAt
  asset       Asset     @relation(fields: [assetId], references: [id])
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id])

  @@unique([portfolioId, assetId])
  @@map("holdings")
}

model Asset {
  id             String       @id @default(uuid())
  symbol         String       @unique
  name           String
  type           AssetType
  basePrice      Float        @default(100.0)
  irSensitivity  Float        @default(0.0)
  infSensitivity Float        @default(0.0)
  gdpSensitivity Float        @default(0.0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  prices         AssetPrice[]
  holdings       Holding[]
  trades         Trade[]

  @@map("assets")
}

model AssetPrice {
  id          String   @id @default(uuid())
  assetId     String
  price       Float
  delta       Float    @default(0)
  sessionId   String?
  roundNumber Int?
  recordedAt  DateTime @default(now())
  asset       Asset    @relation(fields: [assetId], references: [id])

  @@index([assetId, roundNumber])
  @@map("asset_prices")
}

model MacroState {
  id              String      @id @default(uuid())
  sessionId       String
  roundNumber     Int
  interestRate    Float       @default(2.5)
  inflation       Float       @default(3.0)
  gdpGrowth       Float       @default(2.8)
  volatility      Float       @default(0.3)
  blackSwanActive Boolean     @default(false)
  blackSwanTier   Int?
  blackSwanEvent  String?
  createdAt       DateTime    @default(now())
  session         GameSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, roundNumber])
  @@map("macro_states")
}

model Trade {
  id          String    @id @default(uuid())
  portfolioId String
  assetId     String
  roundId     String
  action      String
  quantity    Float
  price       Float
  total       Float
  executedAt  DateTime  @default(now())
  round       Round     @relation(fields: [roundId], references: [id])
  asset       Asset     @relation(fields: [assetId], references: [id])
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id])

  @@index([portfolioId])
  @@index([roundId])
  @@map("trades")
}

model MarketEvent {
  id          String      @id @default(uuid())
  sessionId   String
  roundNumber Int
  title       String
  description String
  impact      String
  triggeredAt DateTime    @default(now())
  session     GameSession @relation(fields: [sessionId], references: [id])

  @@map("market_events")
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  action    String
  resource  String
  metadata  Json?
  ipAddress String?
  userAgent String?
  expiresAt DateTime?
  createdAt DateTime @default(now())
  actor     User?    @relation("ActorLogs", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Score {
  id                String   @id @default(uuid())
  sessionId         String
  userId            String
  sharpeRatio       Float    @default(0)
  maxDrawdown       Float    @default(0)
  assetDiversity    Float    @default(0)
  blackSwanSurvival Float    @default(0)
  finalScore        Float    @default(0)
  gradeReturn       String   @default("C")
  gradeDiversity    String   @default("C")
  gradeRisk         String   @default("C")
  gradeSurvival     String   @default("C")
  geminiAnalysis    String?
  createdAt         DateTime @default(now())

  @@unique([sessionId, userId])
  @@map("scores")
}

model TradeRecord {
  id          String   @id @default(uuid())
  sessionId   String
  playerId    String
  round       Int
  portfolio   String   // JSON snapshot of allocation %
  totalValue  Float
  committedAt DateTime @default(now())
  isAutoLock  Boolean  @default(false)

  @@index([sessionId, playerId])
  @@map("trade_records")
}
