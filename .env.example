# ─── SUPABASE ────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...          # Safe to expose (RLS enforced)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...              # NEVER expose — server only
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ─── NEST.JS API ─────────────────────────────────────────
API_PORT=3001
API_URL=http://localhost:3001                       # Used by Next.js to call the API
JWT_SECRET=your-jwt-secret-min-32-chars            # Must match Supabase JWT secret
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ─── NEXT.JS ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001           # Nest.js API base URL (public)
NEXT_PUBLIC_APP_URL=http://localhost:3000           # App base URL

# ─── SSO / OAUTH ─────────────────────────────────────────
# Configured in Supabase Dashboard → Authentication → Providers
# These are set in Supabase — NOT in your .env directly
# GOOGLE_CLIENT_ID     → set in Supabase Auth settings
# GOOGLE_CLIENT_SECRET → set in Supabase Auth settings
# SAML_METADATA_URL    → set in Supabase Auth settings (Enterprise SSO)

# ─── SOCKET.IO ───────────────────────────────────────────
SOCKET_IO_CORS_ORIGIN=http://localhost:3000        # Comma-separated in production

# ─── SENTRY ──────────────────────────────────────────────
SENTRY_DSN=https://xxx@ooo.ingest.sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@ooo.ingest.sentry.io/xxx

# ─── MISC ────────────────────────────────────────────────
NODE_ENV=development                               # development | staging | production
LOG_LEVEL=debug                                    # debug | info | warn | error
